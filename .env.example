# Copy to .env and fill in before `docker compose up --build`.
# All ingestion/classifier services share this admin key -- the wrapper's
# default/admin usage and the dashboard's Settings page must both be
# configured with the same value. Per-server keys (minted via the API,
# see README section 7) are scoped and separate from this.
MCP_INSIGHT_API_KEY=change-me-to-a-real-secret

# Optional: Slack incoming webhook URL for health/anomaly alerts.
# Leave blank to disable alerting. Treat this as a secret -- anyone with
# it can post messages into your Slack channel.
SLACK_WEBHOOK_URL=

ALERT_SCORE_THRESHOLD=60
ALERT_COOLDOWN_SECONDS=900

# Origins allowed to call the ingestion/classifier APIs from a browser.
DASHBOARD_ORIGINS=http://localhost:5173,http://localhost:4173

# URLs baked into the dashboard's static build -- what the *browser* uses,
# so these must be reachable from wherever the user's browser runs (usually
# localhost during dev), not the Docker-internal service names.
DASHBOARD_INGESTION_URL=http://localhost:8000
DASHBOARD_CLASSIFIER_URL=http://localhost:8100

# Rate limits (requests per minute). See README section 8.
RATE_LIMIT_INGEST_PER_MINUTE=120
RATE_LIMIT_READ_PER_MINUTE=300
RATE_LIMIT_CLASSIFY_PER_MINUTE=300

# Optional: enables the LLM fallback classifier for low-TF-IDF-confidence
# faults. Leave blank to skip it (classifier still works, just TF-IDF-only).
ANTHROPIC_API_KEY=
ANOMALY_ZSCORE_THRESHOLD=3.0
ANOMALY_HISTORY_BUCKETS=8
ANOMALY_MIN_HISTORY_BUCKETS=3
